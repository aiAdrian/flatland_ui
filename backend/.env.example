LOG_LEVEL=info
CORS_ORIGINS=http://localhost:4200

# ---------------------------------------------------------------------------
# LLM provider (app/llm). Full setup guide: docs/reference/llm-setup.md
# Pick ONE of the three blocks below.
# ---------------------------------------------------------------------------

# 1) LOCAL — small model on your own machine, via Ollama. This is the default,
#    and needs no API key. Run `scripts/setup-llm.sh` (or .ps1 on Windows) once.
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:4b
LLM_BASE_URL=http://localhost:11434/v1
# Only 8 GB of RAM? Use the smaller sibling instead:
# LLM_MODEL=qwen3.5:2b

# 2) HOSTED API — Claude. Uncomment and set a key.
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-opus-4-8
# LLM_API_KEY=sk-ant-...
# LLM_EFFORT=medium          # low | medium | high | xhigh | max

# 3) CLOUD-HOSTED — any OpenAI-compatible endpoint (vLLM, TGI, Ollama Cloud, …)
# LLM_PROVIDER=openai_compatible
# LLM_MODEL=Qwen/Qwen3.5-9B
# LLM_BASE_URL=https://your-gpu-box.example.org/v1
# LLM_API_KEY=...

# Shared knobs
LLM_MAX_TOKENS=8192
LLM_TIMEOUT_S=120

# Thinking models (Qwen3.5 and friends) reason before answering, which on a laptop
# costs tens of seconds and can burn the whole token budget before producing any
# answer. "none" makes them answer directly. Applies to the ollama and
# openai_compatible providers; use "" to omit the field for endpoints that reject it.
LLM_REASONING_EFFORT=none

# ---------------------------------------------------------------------------
# Docs Q&A — /llm/chat grounds answers in the repo docs (task.md §9).
# Retrieval always talks to the local OpenAI-compatible endpoint below, even
# when the chat provider above is Claude or a cloud box.
# ---------------------------------------------------------------------------
RAG_ENABLED=true
RAG_EMBED_MODEL=nomic-embed-text
RAG_EMBED_BASE_URL=http://localhost:11434/v1
RAG_TOP_K=4
# Only the *living truth* docs — plans/ describe unbuilt features and would be
# cited as if they existed. Add roots here if the corpus should grow.
RAG_DOCS=README.md,PLAYGROUND.md,docs/README.md,docs/reference,docs/scenarios
